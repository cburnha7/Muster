{
  "expo": {
    "name": "Muster",
    "slug": "muster",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/muster-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D8C5E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.muster.app",
      "buildNumber": "1.0.0",
      "icon": "./assets/muster-icon-1024.png",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to upload profile photos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload profile photos.",
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show nearby facilities and events."
      }
    },
    "android": {
      "package": "com.muster.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/muster-icon-1024.png",
        "backgroundColor": "#3D8C5E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Muster",
      "shortName": "Muster",
      "description": "Find a game. Find your people. - Community sports booking & player recognition",
      "themeColor": "#3D8C5E",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3D8C5E",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload profile pictures."
        }
      ]
    ],
    "scheme": "muster",
    "extra": {
      "eas": {
        "projectId": "e887ba1f-fc8a-40df-a483-202a66a6d6be"
      },
      "router": {}
    }
  }
}
