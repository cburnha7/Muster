{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "SENTRY_ORG": "grange-engineering",
        "SENTRY_PROJECT": "muster"
      },
      "autoIncrement": true,
      "ios": {
        "distribution": "store",
        "credentialsSource": "remote"
      }
    }
  },

  "submit": {
    "production": {
      "ios": {
        "appleId": "burnham_charles@icloud.com",
        "ascAppId": "6760872035",
        "appleTeamId": "Z3KZY6682M"
      }
    }
  }
}
