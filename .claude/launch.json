{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (mobile)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "port": 8082
    },
    {
      "name": "API Server",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd server && npm run dev"],
      "port": 3000
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd server && npm run prisma:studio"],
      "port": 5555
    }
  ]
}
