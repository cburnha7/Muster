{
  "name": "muster-api",
  "version": "1.0.0",
  "description": "Muster API Server",
  "main": "dist/index.js",
  "prisma": {
    "seed": "tsx src/prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc || true",
    "start": "prisma generate && prisma migrate deploy && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "seed:facilities": "tsx src/scripts/seed-facilities-with-courts.ts",
    "seed:test-events": "tsx src/scripts/seed-test-events.ts",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "keywords": [
    "muster",
    "sports",
    "booking",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "6.15.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/sharp": "^0.31.1",
    "jest": "^30.3.0",
    "prisma": "6.15.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
