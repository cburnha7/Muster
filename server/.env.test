# Test Environment Configuration
# This file contains environment variables for testing the authentication system

# Database - Separate test database
DATABASE_URL="postgresql://postgres:password@localhost:5432/muster_test?schema=public"

# Server
PORT=3001
NODE_ENV=test

# JWT - Use different secret for testing
JWT_SECRET=test-jwt-secret-key-for-authentication-testing-only
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8081

# Email Service (SMTP) - Mock email service for testing
# Option 1: Use Ethereal Email (https://ethereal.email/) for testing
# Option 2: Use MailHog (local SMTP server)
# Option 3: Mock email service in tests
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@ethereal.email
SMTP_PASSWORD=test-password
SMTP_FROM_EMAIL=noreply@muster-test.app
SMTP_FROM_NAME=Muster Test

# Frontend URL (for email links in tests)
FRONTEND_URL=http://localhost:8081

# SSO Test Credentials
# Apple Sign In Test Credentials
# Note: Apple Sign In requires a physical iOS device for testing
# Use Apple's sandbox environment for testing
APPLE_CLIENT_ID=com.muster.test
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY_PATH=./config/AuthKey_TEST.p8

# Google Sign In Test Credentials
# Create test credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID_IOS=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Rate Limiting - More lenient for testing
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=5
RATE_LIMIT_MAX_REGISTER=3
RATE_LIMIT_MAX_PASSWORD_RESET=3
