# Database
DATABASE_URL="postgresql://user:password@localhost:5432/muster?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT (MUST be at least 32 characters in production)
JWT_SECRET=your-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:8081

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
PLATFORM_FEE_RATE=0.01

# Stripe Price IDs (subscription products)
STRIPE_PRICE_ROSTER=price_your-roster-price-id
STRIPE_PRICE_LEAGUE=price_your-league-price-id
STRIPE_PRICE_FACILITY_BASIC=price_your-facility-basic-price-id
STRIPE_PRICE_FACILITY_PRO=price_your-facility-pro-price-id

# Memberships / Subscriptions
# Set to "false" to bypass all plan gates (free access to all features)
MEMBERSHIPS_ENABLED=false

# Google Places API (for address autocomplete proxy)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Cloudflare R2 (Image Storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=muster-media
R2_PUBLIC_URL=https://media.muster.app